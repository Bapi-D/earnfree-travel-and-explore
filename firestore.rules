rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function roleDoc(uid) {
      return get(/databases/$(database)/documents/user_roles/$(uid));
    }

    function hasRole(uid, allowed) {
      return signedIn()
        && exists(/databases/$(database)/documents/user_roles/$(uid))
        && roleDoc(uid).data.role in allowed;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return hasRole(request.auth.uid, ['admin']);
    }

    function isStaff() {
      return hasRole(request.auth.uid, ['admin', 'staff']);
    }

    match /profiles/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create, update: if isSelf(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /profile_files/{fileId} {
      allow read: if signedIn() && (resource.data.profile_id == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /user_roles/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId)
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email;
      allow update: if isAdmin()
        || (isSelf(userId)
          && resource.data.role == 'user'
          && request.resource.data.role == 'user'
          && request.resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }

    match /staff_profiles/{staffId} {
      allow read: if isStaff() || isSelf(staffId);
      allow create, update, delete: if isAdmin();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /enquiries/{enquiryId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
